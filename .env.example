# EmailJS – Contact form emails (https://www.emailjs.com/)
# Copy this file to .env.local and fill in your values.

# Your EmailJS Public Key (Dashboard → Account → API Keys)
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key

# Email Service ID (Dashboard → Email Services → create one, e.g. Gmail)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id

# Email Template ID (Dashboard → Email Templates → create one)
# Use these template variables in your EmailJS template:
#   {{from_name}} {{from_email}} {{website}} {{pricing_model}} {{message}}
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_template_id
